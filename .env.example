# 複製此檔為 .env.local 並填入實際值（.env.local 不會被 commit）
# 部署到 Zeabur 時，請在專案的環境變數設定相同的鍵值

# 資料庫連線（Zeabur PostgreSQL）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Google OAuth（Auth.js）— 於 Google Cloud Console 申請
# Authorized redirect URI 需加入 {網域}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth.js session 加密金鑰，可用指令產生：openssl rand -base64 33
AUTH_SECRET=replace-with-a-random-secret
# 非 Vercel 平台（如 Zeabur）需設為 true
AUTH_TRUST_HOST=true
